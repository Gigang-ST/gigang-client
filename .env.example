# Update these with your Supabase details from your project settings > API
# https://app.supabase.com/project/_/settings/api
NEXT_PUBLIC_SUPABASE_URL=your-project-url
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=your-publishable-or-anon-key

# Playwright 스크린샷 테스트용 (선택)
E2E_TEST_EMAIL=test@gigang.dev
E2E_TEST_PASSWORD=your-test-password

# 개발계(Vercel gigang-client-dev)에서만 true 권장. 운영 프로젝트에는 설정하지 마세요.
# 로컬 `pnpm dev`는 NODE_ENV=development 로 자동 표시되므로 생략 가능.
# NEXT_PUBLIC_ENABLE_DEV_EMAIL_LOGIN=true

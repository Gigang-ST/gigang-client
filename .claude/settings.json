{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "language": "korean",
  "alwaysThinkingEnabled": true,
  "enableAllProjectMcpServers": true,
  "permissions": {
    "allow": [
      "Bash(pnpm run dev)",
      "Bash(pnpm run build)",
      "Bash(pnpm run start)",
      "Bash(pnpm run lint)",
      "Bash(gh *)",
      "Bash(cd *)",
      "Read(~/.zshrc)"
    ],
    "deny": [
      "Bash(curl *)",
      "Read(./.env)",
      "Read(./.env.*)",
      "Read(./secrets/**)"
    ]
  },
  "attribution": {
    "commit": "",
    "pr": ""
  }
}
